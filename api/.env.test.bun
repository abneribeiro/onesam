# Test Environment Configuration for Bun Runtime
NODE_ENV=test
PORT=3000

# Database Configuration
DATABASE_URL=postgresql://test:test123@localhost:5433/onesam_test
DATABASE_SSL=false

# Redis Configuration
REDIS_URL=redis://localhost:6380
REDIS_ENABLED=true

# Authentication Configuration
BETTER_AUTH_SECRET=test-secret-key-for-bun-runtime-testing-only
BETTER_AUTH_URL=http://localhost:3002

# Email Configuration (disabled in tests)
EMAIL_ENABLED=false
EMAIL_FROM=test@onesam.com
EMAIL_HOST=localhost
EMAIL_PORT=1025
EMAIL_USER=test
EMAIL_PASS=test

# File Upload Configuration (using local storage in tests)
SUPABASE_URL=http://localhost:54321
SUPABASE_ANON_KEY=test-key
SUPABASE_SERVICE_KEY=test-service-key
UPLOAD_STORAGE=local
UPLOAD_PATH=./test-uploads

# Security Configuration
CORS_ORIGIN=http://localhost:3001
RATE_LIMIT_ENABLED=false

# Logging Configuration
LOG_LEVEL=debug
LOG_FILE=./logs/test.log

# Feature Flags
AUDIT_LOGGING_ENABLED=true
NOTIFICATION_SYSTEM_ENABLED=false

# Test Database Cleanup
AUTO_CLEANUP_TEST_DATA=true
TEST_USER_CLEANUP_INTERVAL=3600000

# Performance Testing
LOAD_TEST_ENABLED=false
BENCHMARK_MODE=false

# Bun Specific Configuration
BUN_ENV=test
BUN_CONFIG_PROFILE=test
BUN_LOG_LEVEL=debug