{
  "name": "api",
  "version": "3.0.0",
  "description": "API for OneSAM application",
  "license": "ISC",
  "author": "abneribeiro",
  "type": "commonjs",
  "main": "app.js",
  "scripts": {
    "build": "bun build src/app.ts --outdir dist --target node",
    "start": "bun run dist/app.js",
    "dev": "bun --hot src/app.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "seed": "bun run src/database/seeds/complete-seed.ts",
    "seed:clean": "bun run src/database/seeds/complete-seed.ts --clean",
    "test": "NODE_ENV=test bun test",
    "test:watch": "NODE_ENV=test bun test --watch",
    "test:coverage": "NODE_ENV=test bun test --coverage",
    "test:security": "NODE_ENV=test bun test src/__tests__/security",
    "test:services": "NODE_ENV=test bun test src/__tests__/services",
    "test:integration": "NODE_ENV=test bun test src/__tests__/integration",
    "test:unit": "NODE_ENV=test bun test --testNamePattern=services",
    "test:ci": "NODE_ENV=test bun test --reporter=junit --output-file=test-results.xml",
    "gap-analysis": "bun run src/scripts/gap-analysis.ts",
    "db:benchmark": "bun run src/scripts/performance-benchmark.ts",
    "test:load": "bun run src/scripts/load-test.ts",
    "security:validate": "bun test src/__tests__/security --verbose",
    "audit:generate-report": "bun run src/scripts/audit-report.ts"
  },
  "dependencies": {
    "@scalar/express-api-reference": "^0.8.22",
    "@supabase/supabase-js": "^2.76.1",
    "@types/ioredis": "^5.0.0",
    "@types/morgan": "^1.9.10",
    "@types/nodemailer": "^7.0.3",
    "axios": "^1.9.0",
    "bcryptjs": "^3.0.3",
    "better-auth": "^1.2.9",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "date-fns": "^2.30.0",
    "dotenv": "^16.5.0",
    "drizzle-orm": "^0.44.6",
    "express": "^5.1.0",
    "express-rate-limit": "^8.2.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.9.2",
    "morgan": "^1.10.1",
    "multer": "^1.4.5-lts.2",
    "node-cron": "^3.0.3",
    "nodemailer": "^7.0.10",
    "pdfkit": "^0.17.1",
    "pg": "^8.15.6",
    "postgres": "^3.4.7",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^13.0.0",
    "winston": "^3.17.0",
    "zod": "^4.1.12",
    "zod-to-openapi": "^0.2.1"
  },
  "devDependencies": {
    "@faker-js/faker": "^9.4.0",
    "@types/bcryptjs": "^3.0.0",
    "@types/cookie-parser": "^1.4.9",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/multer": "^2.0.0",
    "@types/node": "^24.8.1",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.15.5",
    "@types/supertest": "^6.0.3",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/uuid": "^11.0.0",
    "drizzle-kit": "^0.31.5",
    "supertest": "^6.3.3",
    "typescript": "^5.9.3"
  }
}