NODE_ENV=test
PORT=3000

# Application
APP_NAME=OneSAM LMS Test
APP_URL=http://localhost:3000
FRONTEND_URL=http://localhost:3001

# Database (Docker Compose db-test service on port 5433)
DATABASE_URL=postgresql://test:test123@localhost:5433/onesam_test
DATABASE_SSL=false
DATABASE_MAX_CONNECTIONS=5
DATABASE_TIMEOUT=5

# JWT Configuration
JWT_SECRET=test-jwt-secret-key-minimum-32-characters-long
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=test-jwt-refresh-secret-minimum-32-characters
JWT_REFRESH_EXPIRES_IN=30d

# Better Auth
BETTER_AUTH_SECRET=test-better-auth-secret-minimum-32-chars
BETTER_AUTH_URL=http://localhost:3000

# Supabase (placeholder values for test environment)
SUPABASE_URL=http://localhost:54321
SUPABASE_ANON_KEY=test-anon-key-placeholder
SUPABASE_SERVICE_KEY=test-service-key-placeholder

# Logging
LOG_LEVEL=error
LOG_FILE=test.log

# Security
BCRYPT_ROUNDS=4
DISABLE_AUTH=false
