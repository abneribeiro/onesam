# ==================================
# OneSAM LMS - Backend Environment Configuration
# ==================================
# Copy this file to .env and fill in your actual values

# ----------------------------------
# Application Settings
# ----------------------------------
NODE_ENV=development
APP_NAME="OneSAM LMS"
APP_URL=http://localhost:3000
FRONTEND_URL=http://localhost:3001
PORT=3000

# Legacy alias (kept for backward compatibility)
BASE_URL=http://localhost:3000

# ----------------------------------
# Database Configuration
# ----------------------------------
# Supabase PostgreSQL connection
# Transaction Mode (pooled) - recommended for production
DATABASE_URL=postgresql://postgres.[PROJECT_REF]:[PASSWORD]@[REGION].pooler.supabase.com:6543/postgres
DATABASE_SSL=false

# Alternative: Session Mode (direct connection)
# DATABASE_URL=postgresql://postgres.[PROJECT_REF]:[PASSWORD]@[REGION].pooler.supabase.com:5432/postgres

# Legacy DB configs (optional, for tools like Drizzle Studio)
DB_HOST=db.your-project.supabase.co
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=your-password
DB_DATABASE=postgres

# ----------------------------------
# Authentication & Security
# ----------------------------------
# Generate strong secrets using: openssl rand -base64 32
JWT_SECRET=your_jwt_secret_at_least_32_characters_long
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your_refresh_secret_at_least_32_characters_long
JWT_REFRESH_EXPIRES_IN=30d

# Better Auth configuration
BETTER_AUTH_SECRET=your-better-auth-secret-key-here-min-32-chars
BETTER_AUTH_URL=http://localhost:3000

# Password hashing rounds (10-12 recommended)
BCRYPT_ROUNDS=12

# ----------------------------------
# Supabase Configuration
# ----------------------------------
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key-here
SUPABASE_SERVICE_KEY=your-supabase-service-role-key-here

# ----------------------------------
# Email Configuration (Optional)
# ----------------------------------
# For user registration, password reset, notifications
EMAIL_FROM=no-reply@plataformaformacao.pt
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
EMAIL_SECURE=false

# Legacy email config (for backward compatibility)
EMAIL_PASSWORD=your-app-password

# ----------------------------------
# Redis Configuration (Optional)
# ----------------------------------
# For session storage, caching, and rate limiting
REDIS_URL=redis://localhost:6379

# ----------------------------------
# Rate Limiting
# ----------------------------------
RATE_LIMIT_WINDOW_MS=900000  # 15 minutes
RATE_LIMIT_MAX_REQUESTS=100

# ----------------------------------
# CORS Configuration
# ----------------------------------
ALLOWED_ORIGINS=http://localhost:3001,https://yourdomain.com

# ----------------------------------
# File Upload Settings
# ----------------------------------
MAX_FILE_SIZE=10485760  # 10MB in bytes
ALLOWED_FILE_TYPES=jpg,jpeg,png,gif,pdf,doc,docx,ppt,pptx,mp4,webm

# ----------------------------------
# Logging Configuration
# ----------------------------------
LOG_LEVEL=info
LOG_FILE=app.log

# ----------------------------------
# Monitoring (Optional)
# ----------------------------------
# Sentry DSN for error tracking in production
SENTRY_DSN=https://your_sentry_dsn@sentry.io

# ----------------------------------
# Development Only
# ----------------------------------
# WARNING: Never set to true in production!
DISABLE_AUTH=false

# ----------------------------------
# Supabase Storage Buckets
# ----------------------------------
# These will be created automatically via migration:
# - avatars
# - course-images
# - course-content
# - certificates
